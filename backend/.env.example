# ============================================================
# ACOB Odyssey Backend - Environment Variables
# Copy to .env and NEVER commit .env to version control
# ============================================================

# Server
PORT=4000
NODE_ENV=development

# Odyssey API
ODYSSEY_API_BASE_URL=http://8.208.16.168:9310/api
ODYSSEY_JWT_TOKEN=your-jwt-token-here
ODYSSEY_TOKEN_EXPIRY_BUFFER_SECONDS=60

# Sites
ODYSSEY_SITES=KYAKALE,MUSHA,UMAISHA,TUNGA,OGUFA

# Security
JWT_SECRET=change-this-to-a-long-random-secret-in-production
CORS_ORIGIN=http://localhost:5173
ENABLE_DEV_AUTH_BYPASS=false

# Auth users (required outside development)
# JSON array format:
# [{"username":"admin","password":"strong-password","user":{"id":"0001","roleId":"Odyssey","operatorName":"System Administrator","scopes":["*"]}}]
AUTH_OPERATORS_JSON=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
